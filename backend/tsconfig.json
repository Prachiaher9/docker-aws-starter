{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",

    "module": "NodeNext",
    "target": "ES2020",
    "moduleResolution": "NodeNext",

    "esModuleInterop": true,
    "strict": true,

    "types": ["node"],

    "sourceMap": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}